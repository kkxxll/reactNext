# 开发环境配置
# npm start 时自动加载，配合 src/services/questionnaire.ts 中的 useMock 判断
REACT_APP_USE_MOCK=true

# 后端服务基础地址（当 USE_MOCK=false 时生效）
# 开发环境推荐留空，走 craco.config.js 中的 devServer.proxy（/api -> http://localhost:3001）
# 如需直连指定服务可取消以下注释：
# REACT_APP_API_BASE_URL=http://localhost:3001

# craco 代理目标（Node 端变量，不会注入浏览器）
# 默认 http://localhost:3001，需调试别的后端时取消注释：
# PROXY_TARGET=http://localhost:8080
